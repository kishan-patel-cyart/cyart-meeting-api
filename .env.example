# Environment Variables for Meeting Booking API

# Server Configuration
PORT=3001

# Google Calendar Configuration
# The email address of the calendar where events will be created
GOOGLE_CALENDAR_ID=develop.cyart@gmail.com

# Google Service Account credentials (JSON string)
# For local dev, you can use the google-credentials.json file instead
# For production (Railway), paste the entire JSON content of your service account key here
GOOGLE_CREDENTIALS=

# Frontend URL (for CORS)
FRONTEND_URL=https://cyart.in
